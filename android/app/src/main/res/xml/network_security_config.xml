<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext traffic only for development on localhost -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>

    <!-- Default configuration for production - require HTTPS -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">staging-api.doctoping.com</domain>
        <domain includeSubdomains="true">api.doctoping.com</domain>
    </domain-config>
</network-security-config>
